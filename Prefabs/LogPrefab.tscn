[sub_resource type="Shader" id="Shader_inner_wood"]
code = "shader_type spatial;\nrender_mode diffuse_burley;\n\nvoid fragment() {\n\tfloat length_grain = sin(VERTEX.y * 34.0 + sin(VERTEX.x * 18.0) * 0.35 + sin(VERTEX.z * 15.0) * 0.25);\n\tfloat fine_grain = sin(VERTEX.y * 91.0 + VERTEX.x * 7.0) * 0.5 + 0.5;\n\tfloat grain = smoothstep(0.50, 0.92, length_grain * 0.5 + 0.5) * 0.10 + fine_grain * 0.035;\n\tvec3 base_color = vec3(0.72, 0.54, 0.32);\n\tvec3 grain_color = vec3(0.46, 0.30, 0.15);\n\tALBEDO = mix(base_color, grain_color, grain);\n\tROUGHNESS = 0.88;\n}"

