[sub_resource type="Shader" id="Shader_inner_wood"]
code = "shader_type spatial;\nrender_mode diffuse_burley;\n\nvarying vec3 local_pos;\n\nvoid vertex() {\n\tlocal_pos = VERTEX;\n}\n\nvoid fragment() {\n\tfloat length_grain = sin(local_pos.y * 45.0 + sin(local_pos.x * 20.0) * 0.4 + sin(local_pos.z * 20.0) * 0.4);\n\tfloat dist_from_center = length(local_pos.xz);\n\tfloat ring = sin(dist_from_center * 150.0 + sin(local_pos.y * 5.0) * 0.3);\n\tfloat fine_grain = sin(local_pos.y * 120.0 + local_pos.x * 20.0) * 0.5 + 0.5;\n\tfloat grain = smoothstep(0.45, 0.95, length_grain * 0.5 + 0.5) * 0.15 + smoothstep(0.6, 0.95, ring * 0.5 + 0.5) * 0.15 + fine_grain * 0.04;\n\tvec3 base_color = vec3(0.78, 0.62, 0.42);\n\tvec3 grain_color = vec3(0.45, 0.28, 0.12);\n\tALBEDO = mix(base_color, grain_color, grain);\n\tROUGHNESS = 0.9;\n}"

